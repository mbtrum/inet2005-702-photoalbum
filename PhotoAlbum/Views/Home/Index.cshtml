@model List<PhotoAlbum.Models.Photo>

@{
    ViewData["Title"] = "Home Page";
}

<h1>All Photos</h1>

<table class="table w-50">
    <tr>
        <th></th>
        <th>Id</th>
        <th>Title</th>
        <th>Created</th>
        <th></th>
    </tr>
    @foreach (var photo in Model)
    {
        <tr>
            <td>
                <img src="/images/@photo.Filename" alt="@photo.Title" class="thumbnail" />
            </td>
            <td>@photo.PhotoId</td>
            <td>@photo.Title</td>
            <td>@photo.CreateDate.ToString("MMM d, yyyy")</td>
            <td>
                <a asp-controller="Home" asp-action="Details" asp-route-id="@photo.PhotoId">details</a>                
            </td>
        </tr>
    }
</table>

